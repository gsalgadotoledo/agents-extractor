# === LLM ===
ANTHROPIC_API_KEY=sk-ant-...

# === SMTP ===
# For local testing with Mailpit:
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false

# For Gmail (real emails):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx  (Gmail App Password)
# SMTP_USE_TLS=true

EMAIL_FROM_NAME=Underwriting Team at Apex Insurance
EMAIL_FROM_ADDRESS=underwriting@apex-demo.com

# === Mailpit API ===
MAILPIT_API_URL=http://localhost:8025/api/v1

# === App ===
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=DEBUG

# === Inbound SMTP ===
INBOUND_SMTP_HOST=0.0.0.0
INBOUND_SMTP_PORT=2525

# === Gmail API (Push via Pub/Sub) ===
# Step 1: Create OAuth credentials in Google Cloud Console
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Step 2: Run `uv run submission gmail-auth` to get this token
GOOGLE_REFRESH_TOKEN=1//...
# Step 3: Your Gmail address
GMAIL_ADDRESS=your-email@gmail.com
# Step 4: Pub/Sub topic (create with gcloud)
GMAIL_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/gmail-notifications
# Optional settings
GMAIL_RECONCILER_INTERVAL_SECONDS=30
GMAIL_PUBSUB_VERIFICATION_TOKEN=a-random-secret

# === Slack ===
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL=#submissions
# SLACK_APP_TOKEN=xapp-...
# SLACK_SIGNING_SECRET=...
